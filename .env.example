# --- Cognee memory layer (internal LLM used by remember()/cognify) ---
# Groq free tier: fast, and you already have a key from LexScout/CircuitForge.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_groq_key_here

# Local, free, no key needed.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Leave both unset to use Cognee's zero-setup local default (SQLite + LanceDB + Ladybug).
# VECTOR_DB_PROVIDER=lancedb
# GRAPH_DATABASE_PROVIDER=ladybug

# --- Amnesia's own LangGraph planner (separate from Cognee's internal LLM above) ---
GROQ_API_KEY=your_groq_key_here
PLANNER_MODEL=llama-3.3-70b-versatile

# --- Fully offline fallback path (uncomment to use instead of Groq) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# EMBEDDING_PROVIDER=ollama

# --- Cognee Cloud (only if you later decide to hedge into the Cloud track) ---
# COGNEE_API_KEY=your_cognee_cloud_key
# COGNEE_SERVICE_URL=https://platform.cognee.ai
